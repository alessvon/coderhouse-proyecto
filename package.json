{
  "name": "coderhouse-portfolio",
  "version": "3.0.0",
  "description": "Portfolio personal — Roger Grau, Product Engineer. Preentrega 3 Coderhouse.",
  "scripts": {
    "sass:build": "sass scss/main.scss css/style.css --style=expanded --no-source-map",
    "sass:watch": "sass --watch scss/main.scss:css/style.css --style=expanded",
    "sass:prod": "sass scss/main.scss css/style.css --style=compressed --no-source-map"
  },
  "devDependencies": {
    "sass": "^1.77.0"
  }
}
